# ── ScalpFree Backend Configuration ──────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Path to the .hdf5 model file (relative to the backend/ directory)
MODEL_PATH=model/hair-diseases.hdf5

# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Uvicorn bind settings
HOST=0.0.0.0
PORT=8000
